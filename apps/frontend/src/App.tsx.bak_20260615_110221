  useEffect(() => {
    setEmpresa({
      codigo_empresa: empresaAtiva?.codigo_empresa ?? '',
      razao_social: empresaAtiva?.razao_social ?? '',
      nome_fantasia: empresaAtiva?.nome_fantasia ?? '',
