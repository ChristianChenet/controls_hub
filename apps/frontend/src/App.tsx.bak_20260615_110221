                  {evento.etapa_origem_nome || evento.etapa_destino_nome ? ` · ${String(evento.etapa_origem_nome ?? '-')} -> ${String(evento.etapa_destino_nome ?? '-')}` : ''}
                  {evento.descricao ? ` · ${String(evento.descricao)}` : ''}
