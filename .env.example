# ============================================================
# CONTROL S HUB - CONFIGURACAO PADRAO
# Copie este arquivo para .env e ajuste os dados do ambiente.
# O .env oficial deve ficar sempre na raiz do projeto.
# ============================================================

NODE_ENV=production
PORT=3000
JWT_SECRET=altere_esta_chave

# Opcao recomendada para PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/control_s_hub

# Opcao alternativa, caso nao use DATABASE_URL
PGHOST=localhost
PGPORT=5432
PGDATABASE=control_s_hub
PGUSER=postgres
PGPASSWORD=postgres

# Frontend
VITE_API_URL=http://localhost:3000
